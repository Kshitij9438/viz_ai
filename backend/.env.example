# Runtime
ENVIRONMENT=development
PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# Frontend origin, comma-separated when multiple origins are allowed
FRONTEND_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET_KEY=generate-at-least-32-random-characters-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
GUEST_JWT_EXPIRE_HOURS=48

# Database
DATABASE_URL=sqlite+aiosqlite:///./vizzy.db

# Queue, optional. API requests degrade gracefully when Redis is unavailable.
REDIS_URL=redis://localhost:6379/0
QUEUE_JOB_TIMEOUT_SECONDS=180
QUEUE_MAX_TRIES=3

# LLM provider
GITHUB_TOKEN=your_github_models_token_here
GITHUB_MODEL=gpt-4.1-mini
GITHUB_VISION_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=45

# Image generation
IMAGE_BACKEND=pollinations
# HF_TOKEN=hf_xxxxx

# Storage. Supabase is recommended for production.
SUPABASE_URL=
SUPABASE_KEY=
STORAGE_DIR=./storage
MAX_UPLOAD_BYTES=10485760
